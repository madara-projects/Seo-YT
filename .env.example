# Environment settings for YouTube SEO Analyzer

# App metadata
WIN_ENGINE_APP_NAME=YouTube Win-Engine
WIN_ENGINE_APP_VERSION=0.8.0
WIN_ENGINE_APP_ENVIRONMENT=development
WIN_ENGINE_PUBLIC_DIAGNOSTICS_ENABLED=true
WIN_ENGINE_ADMIN_API_TOKEN=
WIN_ENGINE_RATE_LIMIT_WINDOW_SECONDS=60
WIN_ENGINE_RATE_LIMIT_MAX_REQUESTS=60

# YouTube Data API v3
WIN_ENGINE_YOUTUBE_API_KEY=
WIN_ENGINE_YOUTUBE_API_KEYS=
WIN_ENGINE_YOUTUBE_MAX_RESULTS=5

# General
WIN_ENGINE_CACHE_TTL_TRENDING_SECONDS=21600
WIN_ENGINE_CACHE_TTL_EVERGREEN_SECONDS=604800
WIN_ENGINE_REDIS_URL=
WIN_ENGINE_REDIS_KEY_PREFIX=win_engine
WIN_ENGINE_REQUEST_TIMEOUT_SECONDS=10
WIN_ENGINE_DATABASE_PATH=win_engine.db
